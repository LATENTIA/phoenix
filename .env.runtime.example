# Phoenix runtime configuration.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# `.env.example` is committed as the template.
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose up --build


# ---------------------------------------------------------------------------
# Authentication (HTTP Basic). REQUIRED for any non-localhost deployment.
# ---------------------------------------------------------------------------
# Leave BOTH unset to disable auth (local dev only — anyone who can reach
# the host gets full access).
#
# To generate the hash:
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('YOUR-PASSWORD-HERE'))"
# Paste the output (starts with `scrypt:` or `pbkdf2:`) as the value below.
#
# !!! IMPORTANT !!! Docker Compose treats `$` in any env_file value as a
# variable reference and silently eats the parts that follow. Werkzeug
# hashes always contain `$` as a separator (scrypt:...$SALT$HASH), so you
# MUST double them:
#
#   Original output of generate_password_hash:
#     scrypt:32768:8:1$ABCsalt$DEFhash
#                    ^         ^
#   What you paste here (every $ doubled):
#     scrypt:32768:8:1$$ABCsalt$$DEFhash
#
# Compose collapses `$$` back to `$` on its way into the container, so the
# Python code sees the original hash. Skipping this step means the hash
# arrives truncated at `scrypt:32768:8:1` and auth always fails.
#
# Keep this file out of git. The hash is one-way but still sensitive.

PHOENIX_AUTH_USER=admin
PHOENIX_AUTH_PASS_HASH=


# ---------------------------------------------------------------------------
# Flask SECRET_KEY. Used to sign CSRF tokens and session cookies.
# ---------------------------------------------------------------------------
# Without a persistent value, every container restart invalidates open tabs
# (CSRF tokens stop matching). For Docker / EC2 you want a fixed value.
#
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"

PHOENIX_SECRET_KEY=


# ---------------------------------------------------------------------------
# Token storage backend.
# ---------------------------------------------------------------------------
#   plaintext  IBKR Flex tokens stored as-is in data.db. Fine for local Docker.
#   aws        Tokens stored in AWS Secrets Manager. Set this only when
#              running on EC2/ECS with an IAM role that grants
#              secretsmanager:* on phoenix/*.

PHOENIX_SECRETS_BACKEND=plaintext

# Only used when PHOENIX_SECRETS_BACKEND=aws:
# AWS_REGION=eu-west-1
# PHOENIX_SECRETS_PREFIX=phoenix/


# ---------------------------------------------------------------------------
# Network binding. Defaults work for docker-compose. Don't change locally.
# ---------------------------------------------------------------------------
# PHOENIX_BIND_HOST=0.0.0.0
# PHOENIX_PORT=5000


# ---------------------------------------------------------------------------
# HTTPS mode. Set to 1 in production only (behind Caddy / an HTTPS proxy).
# ---------------------------------------------------------------------------
# When 1:
#   - Session cookies get the Secure flag (browser only sends over HTTPS)
#   - HSTS header is emitted (browser refuses HTTP downgrade for 2 years)
# When unset / 0:
#   - Cookies work over plain http://127.0.0.1:5000 for local dev
#   - No HSTS header, so a mistaken `http://phoenix.latentia.ai` reload from
#     an old bookmark isn't pinned forever.
#
# In prod (EC2 behind Caddy) set PHOENIX_HTTPS=1 in the runtime env.

# PHOENIX_HTTPS=1


# ---------------------------------------------------------------------------
# Gunicorn tuning (Docker only; ignored when running `python app.py` locally).
# ---------------------------------------------------------------------------
# Keep WORKERS=1 unless you swap flask-limiter's storage to Redis.
# THREADS controls how many requests one worker can handle in parallel.
# TIMEOUT is per-request in seconds; CGT report on a big account can take a
# while, so 60s is a safe default.

# GUNICORN_WORKERS=1
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=60


# ---------------------------------------------------------------------------
# Persistent data location.
# ---------------------------------------------------------------------------
# Docker bind-mounts this host directory to /app/data inside the container.
# All writable state (data.db, downloaded broker statements, log files) lives
# here. Survives `docker compose down`, `docker compose down -v`, image
# rebuilds, anything except an explicit `rm -rf` of this directory.
#
# Default: ./phoenix-data (a subdir of the project, gitignored).
# EC2:     /var/phoenix-data on an EBS volume (or /mnt/<vol>/phoenix-data).
#
# If you have a pre-existing data.db / downloaded/ / logs/ in the project
# root (from running Phoenix outside Docker), migrate them first:
#     python scripts/migrate-to-docker.py
# That script COPIES (doesn't move) the legacy files into the target dir.

# PHOENIX_DATA_DIR=./phoenix-data
